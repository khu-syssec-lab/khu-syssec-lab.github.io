{% assign focus_items = site.data.research_focus %}
{% assign funded_projects = site.data.funded_projects %}

{% if focus_items and focus_items.size > 0 %}
<section class="research-overview">
  <div class="research-overview-head">
    <h2>Research Focus</h2>
    <p>Core areas where the lab develops practical security analysis, testing, and defense techniques.</p>
  </div>
  <div class="research-focus-grid">
    {% for item in focus_items %}
      <article class="research-focus-card">
        <h3>{{ item.title }}</h3>
        <p>{{ item.description }}</p>
        {% if item.keywords %}<div class="research-focus-keywords">{{ item.keywords }}</div>{% endif %}
      </article>
    {% endfor %}
  </div>
</section>
{% endif %}

{% if funded_projects and funded_projects.size > 0 %}
{% assign current_projects = funded_projects | where_exp: "project", "project.status != 'past'" %}
{% assign past_projects = funded_projects | where: "status", "past" %}
<section class="funded-projects">
  <div class="research-overview-head">
    <h2>Funded Projects</h2>
    <p>Selected externally funded and collaborative research projects.</p>
  </div>

  {% if current_projects.size > 0 %}
  <h3 class="funded-project-subhead">Current Projects</h3>
  <div class="funded-project-list">
    {% for project in current_projects %}
      <article class="funded-project-card">
        <div class="funded-project-period">{{ project.period }}</div>
        <div class="funded-project-main">
          <h3>{{ project.title }}</h3>
          <div class="funded-project-meta">
            <span>{{ project.sponsor }}</span>
          </div>
        </div>
      </article>
    {% endfor %}
  </div>
  {% endif %}

  {% if past_projects.size > 0 %}
  <h3 class="funded-project-subhead funded-project-subhead-past">Past Projects</h3>
  <div class="funded-project-list funded-project-list-past">
    {% for project in past_projects %}
      <article class="funded-project-card">
        <div class="funded-project-period">{{ project.period }}</div>
        <div class="funded-project-main">
          <h3>{{ project.title }}</h3>
          <div class="funded-project-meta">
            <span>{{ project.sponsor }}</span>
          </div>
        </div>
      </article>
    {% endfor %}
  </div>
  {% endif %}
</section>
{% endif %}
